{{ define "slack.aegisops.title" -}}
{{ if eq .Status "firing" }}🔥{{ else }}✅{{ end }} [{{ .Status | toUpper }}] {{ .GroupLabels.alertname }}
{{- end }}

{{ define "slack.aegisops.text" -}}
{{ range .Alerts }}
*Alert:* {{ .Labels.alertname }}
*Severity:* {{ .Labels.severity }}
*Component:* {{ .Labels.component }}
*Description:* {{ .Annotations.description }}
*Started:* {{ .StartsAt.Format "2006-01-02 15:04:05 UTC" }}
{{ if .EndsAt }}*Resolved:* {{ .EndsAt.Format "2006-01-02 15:04:05 UTC" }}{{ end }}
{{ end }}
{{- end }}

{{ define "grafana.url" -}}
http://localhost:3001/alerting/list
{{- end }}

{{ define "alertmanager.silence.url" -}}
http://localhost:9093/#/silences/new?filter=%7Balertname%3D%22{{ .GroupLabels.alertname }}%22%7D
{{- end }}

{{ define "email.aegisops.html" -}}
<!DOCTYPE html>
<html>
<head>
    <style>
        body { font-family: Arial, sans-serif; margin: 0; padding: 20px; background-color: #f5f5f5; }
        .container { max-width: 600px; margin: 0 auto; background: white; border-radius: 8px; overflow: hidden; }
        .header { padding: 20px; text-align: center; }
        .header.firing { background: #f44336; color: white; }
        .header.resolved { background: #4caf50; color: white; }
        .content { padding: 20px; }
        table { width: 100%; border-collapse: collapse; margin: 15px 0; }
        td { padding: 10px; border-bottom: 1px solid #eee; }
        .label { font-weight: bold; width: 30%; }
        .footer { background: #f5f5f5; padding: 15px; text-align: center; font-size: 12px; }
        .btn { display: inline-block; padding: 10px 20px; background: #2196f3; color: white; text-decoration: none; border-radius: 4px; margin: 5px; }
    </style>
</head>
<body>
    <div class="container">
        <div class="header {{ .Status }}">
            <h2>{{ if eq .Status "firing" }}🔥 Alert Firing{{ else }}✅ Alert Resolved{{ end }}</h2>
            <h3>{{ .GroupLabels.alertname }}</h3>
        </div>
        <div class="content">
            {{ range .Alerts }}
            <table>
                <tr><td class="label">Severity</td><td>{{ .Labels.severity }}</td></tr>
                <tr><td class="label">Component</td><td>{{ .Labels.component }}</td></tr>
                <tr><td class="label">Description</td><td>{{ .Annotations.description }}</td></tr>
                <tr><td class="label">Started</td><td>{{ .StartsAt.Format "2006-01-02 15:04:05 UTC" }}</td></tr>
                {{ if .EndsAt }}<tr><td class="label">Resolved</td><td>{{ .EndsAt.Format "2006-01-02 15:04:05 UTC" }}</td></tr>{{ end }}
            </table>
            {{ end }}
            <p style="text-align: center;">
                <a href="{{ template "grafana.url" . }}" class="btn">View in Grafana</a>
                <a href="{{ template "alertmanager.silence.url" . }}" class="btn">Silence Alert</a>
            </p>
        </div>
        <div class="footer">
            <p>AegisOps Observability Service</p>
        </div>
    </div>
</body>
</html>
{{- end }}
