# ===================================
# AGENT ORCHESTRATION SERVICE
# ===================================

# Service Configuration
SERVICE_NAME=agent-orchestration
SERVICE_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# API Configuration
HOST=0.0.0.0
PORT=8002
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# ===================================
# DATABASE CONFIGURATION
# ===================================
DATABASE_URL=postgresql+asyncpg://postgres:YOUR_PASSWORD@localhost:5432/aegisops
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=2792002
POSTGRES_DB=aegisops
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# ===================================
# REDIS CONFIGURATION
# ===================================
REDIS_URL=redis://localhost:6379/2
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=2

# ===================================
# SERVICE URLS (Internal Docker Network)
# ===================================
CONTEXT_MGMT_URL=http://context-management:8000
RAG_SERVICE_URL=http://rag:8000
MCP_SERVICE_URL=http://mcp:8005
MCP_API_KEY=dev-mcp-key
MCP_API_KEY_HEADER=X-API-Key
OBSERVABILITY_SERVICE_URL=http://observability:8003
USER_MANAGEMENT_URL=http://user-management:8004

# ===================================
# SERVICENOW CONFIGURATION
# ===================================
SNOW_INSTANCE=your-instance.service-now.com
SNOW_USERNAME=your_username
SNOW_PASSWORD=YOUR_SNOW_PASSWORD

# ===================================
# VMWARE CONFIGURATION
# ===================================
VCENTER_HOST=vcenter.example.com
VCENTER_USERNAME=administrator@vsphere.local
VCENTER_PASSWORD=YOUR_VCENTER_PASSWORD
VCENTER_VERIFY_SSL=false

# ===================================
# AWS CONFIGURATION (Optional)
# ===================================
AWS_ACCESS_KEY_ID= xxxxx
AWS_SECRET_ACCESS_KEY= xxxxx
AWS_REGION=us-east-1

# ===================================
# OBSERVABILITY
# ===================================
PROMETHEUS_PORT=9002
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAME=agent-orchestration

# ===================================
# SRE INCIDENT SCOPE DEFAULTS
# ===================================
# Allowed incident environments (comma-separated)
SRE_ALLOWED_ENVIRONMENTS=dev,staging,prod
# Optional defaults used when clients request "use default scope"
SRE_DEFAULT_INCIDENT_ENVIRONMENT=
SRE_DEFAULT_CLOUD_PROVIDERS=
SRE_DEFAULT_RESOURCE_TYPES=
SRE_DEFAULT_REGIONS=
# Number of top-ranked cloud providers to probe first
SRE_CLOUD_PROBE_TOP_N=2
# Capability contract catalog (repo-local YAML)
SRE_CAPABILITY_CONTRACTS_PATH=app/prompts/sre_multi_agent/capability_contracts.yaml
